/* =============================
   Global Reset
============================= */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Arial', sans-serif;
  scroll-behavior: smooth;
}

/* =============================
   Body & Background
============================= */
body {
  background: linear-gradient(135deg, #020617, #0f172a);
  color: #ffffff;
}

/* =============================
   Navigation
============================= */
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 60px;
  background: #020617;
  position: sticky;
  top: 0;
  z-index: 100;
}

.logo {
  color: #38bdf8;
  font-size: 26px;
}

nav ul {
  display: flex;
  list-style: none;
}

nav ul li {
  margin-left: 20px;
}

nav ul li a {
  color: white;
  text-decoration: none;
  font-weight: bold;
  transition: color 0.3s;
}

nav ul li a:hover {
  color: #38bdf8;
}

/* =============================
   Home Section (Centered)
============================= */
.home {
  height: 100vh; /* full viewport */
  display: flex;
  flex-direction: column; /* stack items vertically */
  justify-content: center; /* vertical center */
  align-items: center;     /* horizontal center */
  text-align: center;
  padding: 20px;
}

.home h1 {
  font-size: 55px;
  margin-bottom: 15px;
}

.home h1 span {
  color: #38bdf8;
}

.home h2 {
  font-size: 28px;
  margin-bottom: 20px;
}

.home p {
  font-size: 18px;
  margin-bottom: 25px;
}

.home .btn {
  display: inline-block;
  padding: 12px 30px;
  background: #38bdf8;
  border-radius: 8px;
  text-decoration: none;
  color: black;
  font-weight: bold;
  transition: transform 0.3s, background 0.3s;
}

.home .btn:hover {
  background: #22a0f0;
  transform: scale(1.05);
}

/* =============================
   Sections
============================= */
.section {
  padding: 80px 20px;
  text-align: center;
}

/* =============================
   Skills Section
============================= */
.skills {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20px;
  margin-top: 30px;
}

.card {
  background: rgba(30, 41, 59, 0.95);
  padding: 20px;
  border-radius: 10px;
  width: 180px;
  transition: transform 0.3s, background 0.3s;
}

.card:hover {
  transform: scale(1.1);
  background: rgba(51, 65, 85, 0.95);
}

/* =============================
   Projects Section
============================= */
.projects {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20px;
  margin-top: 30px;
}

.project-card {
  background: rgba(30, 41, 59, 0.95);
  padding: 25px;
  border-radius: 10px;
  width: 260px;
  transition: transform 0.3s, background 0.3s;
}

.project-card:hover {
  transform: scale(1.05);
  background: rgba(51, 65, 85, 0.95);
}

/* =============================
   Contact Section
============================= */
section#contact button {
  padding: 12px 25px;
  border: none;
  border-radius: 8px;
  background: #38bdf8;
  color: black;
  cursor: pointer;
  font-weight: bold;
  transition: transform 0.3s, background 0.3s;
}

section#contact button:hover {
  background: #22a0f0;
  transform: scale(1.05);
}

/* =============================
   Footer
============================= */
footer {
  text-align: center;
  padding: 20px;
  background: #020617;
  margin-top: 40px;
}

/* =============================
   Responsive
============================= */
@media (max-width: 768px) {
  nav {
    flex-direction: column;
  }

  nav ul {
    flex-direction: column;
    margin-top: 10px;
  }

  nav ul li {
    margin-left: 0;
    margin-bottom: 10px;
  }

  .home h1 {
    font-size: 40px;
  }

  .home h2 {
    font-size: 22px;
  }

  .skills, .projects {
    flex-direction: column;
    gap: 15px;
  }

  .card, .project-card {
    width: 80%;
    margin: 0 auto;
  }
}
